# Only the Key Vault URL lives here. Every real secret (Storage connection
# string, Document Intelligence key/endpoint, AI Search key/endpoint,
# Azure OpenAI key/endpoint) is stored in Key Vault and fetched at runtime
# via DefaultAzureCredential (your own `az login` session) -- see
# shared/azure_clients.py. Never put real keys in this file or commit .env.

AZURE_KEY_VAULT_URL=
